# =============================================================================
# ContaIA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env com valores reais.
# =============================================================================

# --- Obrigatórias em produção ---

# Chave secreta do Flask para assinar sessões.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-longa-aqui

# Chave da API Anthropic (Claude).
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Credenciais da conta administrador inicial.
# Criada automaticamente na primeira inicialização.
ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=troque-por-senha-forte

# --- Opcionais ---

# Ambiente: "development" ou "production" (padrão: production)
FLASK_ENV=production

# URL do banco de dados.
# Padrão: SQLite local (sqlite:///contaia.db)
# Para PostgreSQL: postgresql://usuario:senha@host:5432/contaia
# DATABASE_URL=sqlite:///contaia.db
