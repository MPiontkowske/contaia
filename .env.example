# =============================================================================
# ContaIA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env com valores reais.
# =============================================================================

# --- Obrigatórias em produção ---

# Chave secreta do Flask para assinar sessões.
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-aleatoria-longa-aqui

# Chave da API Anthropic (Claude).
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Credenciais da conta administrador inicial.
# Criada automaticamente na primeira inicialização.
ADMIN_EMAIL=admin@seudominio.com.br
ADMIN_PASSWORD=troque-por-senha-forte

# --- Opcionais ---

# Ambiente: "development" ou "production" (padrão: production)
FLASK_ENV=production

# URL do banco de dados.
# Padrão: SQLite local (sqlite:///contaia.db)
# Para PostgreSQL: postgresql://usuario:senha@host:5432/contaia
# DATABASE_URL=sqlite:///contaia.db

# --- E-mail transacional (Flask-Mail) ---
# Necessário para enviar o aviso D-2 antes do trial expirar.
# Exemplo com Gmail (requer "Senha de app" nas configurações da conta Google):
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=seuemail@gmail.com
# MAIL_PASSWORD=sua-senha-de-app
# MAIL_DEFAULT_SENDER=ContaIA <noreply@contaia.com.br>

# --- Monitoramento (Sentry) ---
# Obtenha o DSN em: https://sentry.io
# SENTRY_DSN=https://....ingest.sentry.io/...

# --- WhatsApp para upgrade ---
# Número no formato internacional sem + (ex: 5511999999999)
# WHATSAPP_NUMBER=5511999999999
